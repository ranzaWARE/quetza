# Copia questo file in .env e compila i valori
# cp .env.example .env

# Porta su cui gira l'app (default 3000)
PORT=3000

# Stringa segreta per le sessioni — CAMBIALA con qualcosa di lungo e casuale
SESSION_SECRET=metti_qui_una_stringa_lunga_e_casuale_almeno_32_caratteri

# ── LDAP / Active Directory ──────────────────────────────
LDAP_ENABLED=true

# IP o hostname del Domain Controller
LDAP_URL=ldap://192.168.1.10:389

# Service account per la ricerca utenti (sola lettura)
LDAP_BIND_DN=CN=svc_quetza,OU=ServiceAccounts,DC=graphimecc,DC=local
LDAP_BIND_PASSWORD=password_del_service_account

# Base di ricerca degli utenti
LDAP_SEARCH_BASE=DC=graphimecc,DC=local

# Filtro: sAMAccountName = username Windows
LDAP_SEARCH_FILTER=(sAMAccountName={{username}})

# false = accetta certificati self-signed (comune in ambienti AD interni)
LDAP_TLS_REJECT_UNAUTHORIZED=false
